# Resend Email
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@blomtotaalrenovatie.nl

# Vercel Blob
BLOB_READ_WRITE_TOKEN=your_blob_token_here

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://blomtotaalrenovatie.nl
NEXT_PUBLIC_GA_ID=your_google_analytics_id
NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_search_console_code

# Optional: Cloudflare Turnstile (for form spam protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key
